# .gitignore template for Expo
# website: https://expo.dev/
# docs: https://docs.expo.dev/workflow/expo-cli/
#
# Rationale:
# node_modules/ is always ignored

# Node modules
node_modules/

# Environment variables
.env
.env.local
.env.*.local

# Package manager logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

.claude/

.DS_Store
